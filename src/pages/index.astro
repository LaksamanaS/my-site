astro---
const name = "Laksamana S";
const tagline = "Policy analyst. I write about the places I end up in.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name}</title>
  </head>
  <body>
    <header class="intro">
      <h1>{name}</h1>
      <p>{tagline}</p>
    </header>

    <main class="doors">
      <a class="panel bio" href="/about">
        <h2>Laksamana's Profile</h2>
        <span class="enter">Enter</span>
      </a>
      <a class="panel travel" href="/blog">
        <h2>Laksamana Journal On The Run</h2>
        <span class="enter">Enter</span>
      </a>
    </main>
  </body>
</html>

<style>
  body { margin: 0; font-family: system-ui, sans-serif; }

  .intro { padding: 2.5rem 1.5rem 1.5rem; text-align: center; color: #f1efe8; }
  .intro h1 { margin: 0; font-size: 2rem; font-weight: 400; }
  .intro p { margin: 0.5rem 0 0; font-size: 0.9rem; opacity: 0.85; }

  main.doors {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 10px;
    padding: 0 1.25rem 2rem;
    box-sizing: border-box;
    background-image:
      linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.7)),
      url('/portrait.jpg');
    background-size: cover;
    background-position: center;
  }

  .panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem;
    text-decoration: none;
    color: #f1efe8;
    border: 1px solid rgba(255,255,255,0.55);
    background: rgba(0,0,0,0.35);
  }
  .panel h2 { margin: 0; font-weight: 400; font-size: 1.15rem; }

  .enter {
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  @media (min-width: 700px) {
    main.doors {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
      padding: 0;
      background-image: none;
      min-height: 78vh;
    }
    .panel {
      justify-content: center;
      border: none;
      background-size: cover;
      background-position: center;
    }
    .panel h2 { font-size: 1.5rem; }
    .enter { border: 1px solid currentColor; padding: 0.5rem 1.2rem; }
    .bio {
      background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.5)), url('/bio.jpg');
    }
    .travel {
      background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.5)), url('/travel.jpg');
    }
  }
</style>